{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": [
      "jest",
      "@testing-library/jest-dom",
    ],
    "outDir": "./dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": [
    "src/**/*",
  ],
  "exclude": [
    "src/**/*.cy.ts",
    "src/**/*.cy.tsx"
  ],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../editable"
    },
    {
      "path": "../utils"
    }
  ]
}