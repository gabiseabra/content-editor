{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "outDir": "./dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["@ce/common"]
  },
  "include": ["src/**/*", ".storybook/**/*"],
  "references": [
    { "path": "../editor" },
    { "path": "../editable" },
    { "path": "../common" }
  ]
}
