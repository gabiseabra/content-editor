{
  "name": "@content-editor/core",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./use-content-editor": {
      "source": "./src/hooks/use-content-editor.ts",
      "types": "./dist/src/hooks/use-content-editor.d.ts",
      "default": "./dist/src/hooks/use-content-editor.js"
    },
    "./use-editor-changeset": {
      "source": "./src/hooks/use-editor-changeset.tsx",
      "types": "./dist/src/hooks/use-editor-changeset.d.ts",
      "default": "./dist/src/hooks/use-editor-changeset.js"
    },
    "./use-editor-plugins": {
      "source": "./src/hooks/use-editor-plugins.ts",
      "types": "./dist/src/hooks/use-editor-plugins.d.ts",
      "default": "./dist/src/hooks/use-editor-plugins.js"
    },
    "./use-editor-target": {
      "source": "./src/hooks/use-editor-target.tsx",
      "types": "./dist/src/hooks/use-editor-target.d.ts",
      "default": "./dist/src/hooks/use-editor-target.js"
    },
    "./use-editor-traversal": {
      "source": "./src/hooks/use-editor-traversal.ts",
      "types": "./dist/src/hooks/use-editor-traversal.d.ts",
      "default": "./dist/src/hooks/use-editor-traversal.js"
    },
    "./use-event-listener-plugin": {
      "source": "./src/hooks/use-event-listener-plugin.ts",
      "types": "./dist/src/hooks/use-event-listener-plugin.d.ts",
      "default": "./dist/src/hooks/use-event-listener-plugin.js"
    },
    "./use-event-listener": {
      "source": "./src/hooks/use-event-listener.ts",
      "types": "./dist/src/hooks/use-event-listener.d.ts",
      "default": "./dist/src/hooks/use-event-listener.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.2.3"
  },
  "dependencies": {
    "@content-editor/utils": "*",
    "typescript-event-target": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.9",
    "web-streams-polyfill": "^4.2.0"
  }
}
